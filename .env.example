# =============================================================================
# Infrastructure / orchestration env  (.env)
# -----------------------------------------------------------------------------
# Read by `docker compose` for ${VAR} interpolation and consumed by the
# postgres / minio / ocr-engine containers. These are NOT app settings
# (the app's pydantic Settings does not accept them).
#
#   - App settings (api + workers) live in .env.app  (loaded via env_file:)
#   - Local uvicorn dev lives in .env.local
#   - Compat dev lives in compat/.env.compat
#
# NOTE: MinIO creds here are the bucket-server ROOT credentials and must match
#       the MINIO_*_ACCESS_KEY / SECRET_KEY in .env.app (the client side).
# Copy to `.env` and adjust.
# =============================================================================

# Postgres container + DATABASE_URL in .env.app must agree
POSTGRES_USER=taas
POSTGRES_PASSWORD=taas
POSTGRES_DB=taas

# MinIO root credentials (incoming server)
MINIO_INCOMING_ACCESS_KEY=minioincoming
MINIO_INCOMING_SECRET_KEY=minioincoming

# MinIO root credentials (results server)
MINIO_RESULTS_ACCESS_KEY=minioresults
MINIO_RESULTS_SECRET_KEY=minioresults

# OCR engine (TuzkaOCR) API key — ocr-engine container + seed script
OCR_ENGINE_API_KEY=test-engine-key
