# =============================================================================
# Application settings  (.env.app)
# -----------------------------------------------------------------------------
# Every field of app/config.Settings. Loaded into the api + worker containers
# via `env_file:` in docker-compose.yml, so values here actually take effect.
# Uses in-cluster hostnames. For local uvicorn dev, use .env.local instead.
# Copy to `.env.app` and adjust.
# =============================================================================

# Postgres (must match POSTGRES_* in .env)
DATABASE_URL=postgresql+asyncpg://taas:taas@postgres:5432/taas

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO incoming (creds must match .env root creds)
MINIO_INCOMING_URL=http://minio-incoming:9000
MINIO_INCOMING_ACCESS_KEY=minioincoming
MINIO_INCOMING_SECRET_KEY=minioincoming
MINIO_INCOMING_BUCKET=incoming

# MinIO results
MINIO_RESULTS_URL=http://minio-results:9010
MINIO_RESULTS_ACCESS_KEY=minioresults
MINIO_RESULTS_SECRET_KEY=minioresults
MINIO_RESULTS_BUCKET=results

# Auth — CHANGE BOTH FOR ANY REAL DEPLOYMENT
MASTER_KEY=test-master-key
# `make env` fills this with a fresh key; or generate one with `make secret`
KEY_ENCRYPTION_SECRET=change-me-generate-with-fernet

# Upload constraints
ALLOWED_EXTENSIONS=[".tif",".tiff",".jpg",".jpeg",".png"]
MAX_UPLOAD_BYTES=104857600

# Workers
SUBMIT_TICK_SECONDS=2.0
POLLER_TICK_SECONDS=2.0
POLLER_HARVEST_CONCURRENCY=10
JOB_TTL_SECONDS=3600
POLL_BACKOFF_INITIAL=2.0
POLL_BACKOFF_MAX=30.0

# Compression
ZSTD_COMPRESSION_LEVEL=3

# Rate limiting
RATE_LIMIT_SUBMIT_PER_MINUTE=60
RATE_LIMIT_QUERY_PER_MINUTE=120
RATE_LIMIT_WS_CONNECTS_PER_MINUTE=5

# WebSocket
WS_CATCH_UP_SECONDS=120

# Presigned URLs
PRESIGNED_TTL_MINUTES=60
