# Compat server settings. For local dev copy to `.env.compat` and use localhost
# (TAAS_BASE_URL=http://localhost:8080). In Docker the compat container is
# configured via the `environment:` block in docker-compose.yml.

TAAS_BASE_URL=http://localhost:8080
REDIS_URL=redis://localhost:6379/0
COMPAT_TTL_SECONDS=3600
ENGINES={"1": {"domain": "", "label": "Default", "description": "Default OCR engine"}, "2": {"domain": "kramarky", "label": "Kramarky", "description": "Engine for kramarky domain"}}
