# Copy to `.env` and fill in. Used by compose.yaml + frpc.toml.

# --- Tunnel (frpc -> in-cluster frps) ---
# A cluster node IP reachable from this box, and the frps NodePort (tunnel.service.nodePort).
FRP_SERVER_ADDR=10.0.0.10
FRP_SERVER_PORT=32700
# Must equal the cluster's Helm value secrets.frpToken.
FRP_TOKEN=replaceMe

# --- This box / engine identity ---
# BOX_NAME prefixes the exporter proxy names (keep unique per box). ENGINE_NAME is the
# frpc proxy name for the engine. REMOTE_PORT MUST equal this engine's
# tunnelBoxes[].engines[].remotePort in the Helm values, and be unique across all boxes.
BOX_NAME=box1
ENGINE_NAME=gpu1
REMOTE_PORT=8000

# --- Exporters (optional; single-engine compose.yaml) ---
# Tunnel this box's cAdvisor / GPU exporter to the cluster Prometheus. Leave unset to
# skip (the frpc.toml blocks drop out). Each MUST equal this box's
# tunnelBoxes[].exporters[].remotePort and be unique across all boxes.
# FRP_CADVISOR_REMOTE_PORT=8010
# FRP_GPU_EXPORTER_REMOTE_PORT=8011

# --- OCR engine ---
# Must equal the cluster's Helm value secrets.ocrEngineApiKey.
OCR_API_KEY=replaceMe
# cpu (default) or cuda. For cuda you MUST also add the GPU overlay on `up`
# (see README) and use a CUDA image/Dockerfile.gpu.
OCR_DEVICE=cpu

# Run mode: "registry" (pull OCR_IMAGE) or "build" (build from ./TuzkaOCR).
COMPOSE_PROFILES=registry
# registry mode — override for a different / GPU-specific image tag.
# OCR_IMAGE=registry.gitlab.mzk.cz/osdd/image/tuzka-as-a-service/tuzkaocr:1.3.0
# build mode — local checkout to build from (Dockerfile = CPU, Dockerfile.gpu = GPU).
# OCR_BUILD_CONTEXT=./TuzkaOCR
# OCR_DOCKERFILE=Dockerfile
