# =============================================================================
# Local development settings  (.env.local)
# -----------------------------------------------------------------------------
# Same keys as .env.app but pointed at localhost, for running the api/workers
# directly with uvicorn against dockerized infra:
#   docker compose up -d postgres redis minio-incoming minio-results minio-init
#   uvicorn app.main:app --reload
# app/config.Settings reads this file by default (env_file=".env.local").
# Copy to `.env.local` and adjust.
# =============================================================================

DATABASE_URL=postgresql+asyncpg://taas:taas@localhost:5432/taas
REDIS_URL=redis://localhost:6379/0

MINIO_INCOMING_URL=http://localhost:9000
MINIO_INCOMING_ACCESS_KEY=minioincoming
MINIO_INCOMING_SECRET_KEY=minioincoming
MINIO_INCOMING_BUCKET=incoming

MINIO_RESULTS_URL=http://localhost:9010
# Already host-reachable here, so MINIO_RESULTS_PUBLIC_URL can stay unset (falls back to the above).
MINIO_RESULTS_ACCESS_KEY=minioresults
MINIO_RESULTS_SECRET_KEY=minioresults
MINIO_RESULTS_BUCKET=results

MASTER_KEY=change-me
KEY_ENCRYPTION_SECRET=change-me-generate-with-fernet

ALLOWED_EXTENSIONS=[".tif",".tiff",".jpg",".jpeg",".png"]
MAX_UPLOAD_BYTES=104857600

SUBMIT_TICK_SECONDS=2.0
POLLER_TICK_SECONDS=2.0
POLLER_HARVEST_CONCURRENCY=10
JOB_TTL_SECONDS=3600
POLL_BACKOFF_INITIAL=2.0
POLL_BACKOFF_MAX=30.0

ZSTD_COMPRESSION_LEVEL=3

WS_CATCH_UP_SECONDS=120

PRESIGNED_TTL_MINUTES=60
